rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────

    // Check if user is a platform superadmin (costs 1 read, cached per request)
    function isSuperAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u != null && u.data.get('isSuperAdmin', false) == true;
    }

    // Get workspace doc (costs 1 read, cached per request for same path)
    function getWorkspace(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)).data;
    }

    // Check if workspace is active (undefined treated as active for legacy docs)
    function isWorkspaceActive(wsId) {
      return getWorkspace(wsId).get('isActive', true) != false;
    }

    // Check if user is a member of workspace
    function isMember(wsId) {
      return request.auth.uid in getWorkspace(wsId).members;
    }

    // Get user's role in workspace
    function getRole(wsId) {
      return getWorkspace(wsId).memberRoles[request.auth.uid].role;
    }

    // Check if user is the workspace owner
    function isOwner(wsId) {
      return getWorkspace(wsId).ownerId == request.auth.uid;
    }

    // Check if user can edit (OWNER, ADMIN, or EDITOR)
    function canEdit(wsId) {
      let role = getRole(wsId);
      return role == 'OWNER' || role == 'ADMIN' || role == 'EDITOR';
    }

    // Check if user can manage (OWNER or ADMIN)
    function canManage(wsId) {
      let role = getRole(wsId);
      return role == 'OWNER' || role == 'ADMIN';
    }

    // Get the wsId from a parent environment doc (used by subcollection rules)
    function envWsId(envId) {
      return get(/databases/$(database)/documents/environments/$(envId)).data.wsId;
    }

    // ─── Users ────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if request.auth.uid == uid || isSuperAdmin();
      allow list:  if isSuperAdmin();
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Platform Config ──────────────────────────────────────────────

    match /platformConfig/{docId} {
      allow read:  if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // ─── Workspaces ───────────────────────────────────────────────────

    match /workspaces/{wsId} {
      // Members can read only when workspace is active; superadmin always
      allow read: if request.auth != null
                  && (isSuperAdmin()
                      || (request.auth.uid in resource.data.members
                          && resource.data.get('isActive', true) != false));

      // Any authenticated user can create a workspace (they become OWNER)
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.members;

      // OWNER/ADMIN can update only when active; superadmin always (to flip isActive)
      allow update: if request.auth != null
                    && (isSuperAdmin()
                        || ((canManage(wsId) && isWorkspaceActive(wsId))
                            && (isOwner(wsId)
                                || request.resource.data.ownerId == resource.data.ownerId)));

      allow delete: if request.auth != null
                    && (isOwner(wsId) || isSuperAdmin());
    }

    // ─── Projects ─────────────────────────────────────────────────────

    match /projects/{projId} {
      allow read: if request.auth != null
                  && (isSuperAdmin()
                      || (isMember(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow create: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(request.resource.data.wsId) && isWorkspaceActive(request.resource.data.wsId)));

      allow update: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow delete: if request.auth != null
                    && (isSuperAdmin()
                        || (canManage(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));
    }

    // ─── Environments (with embedded urls, servers, vars) ─────────────

    match /environments/{envId} {
      allow read: if request.auth != null
                  && (isSuperAdmin()
                      || (isMember(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow create: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(request.resource.data.wsId) && isWorkspaceActive(request.resource.data.wsId)));

      allow update: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow delete: if request.auth != null
                    && (isSuperAdmin()
                        || (canManage(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      // ─── URLs subcollection ───────────────────────────────────────

      match /urls/{urlId} {
        allow read: if request.auth != null
                    && (isSuperAdmin()
                        || (isMember(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow create: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow update: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow delete: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));
      }

      // ─── Servers subcollection ────────────────────────────────────

      match /servers/{serverId} {
        allow read: if request.auth != null
                    && (isSuperAdmin()
                        || (isMember(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow create: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow update: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow delete: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));
      }

      // ─── Variables subcollection ──────────────────────────────────

      match /vars/{varId} {
        allow read: if request.auth != null
                    && (isSuperAdmin()
                        || (isMember(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow create: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow update: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));

        allow delete: if request.auth != null
                      && (isSuperAdmin()
                          || (canEdit(envWsId(envId)) && isWorkspaceActive(envWsId(envId))));
      }
    }

    // ─── Invite Links (flat collection, token = doc ID) ───────────────

    match /inviteLinks/{token} {
      // Anyone authenticated can read — joining an inactive workspace is blocked at joinRequests level
      allow read: if request.auth != null;

      // Only workspace OWNER can create invite links (workspace must be active)
      allow create: if request.auth != null
                    && isOwner(request.resource.data.wsId)
                    && isWorkspaceActive(request.resource.data.wsId);

      // Only OWNER can update (deactivate) links
      allow update: if request.auth != null
                    && (isSuperAdmin() || isOwner(resource.data.wsId));

      // Only OWNER can delete links
      allow delete: if request.auth != null
                    && (isSuperAdmin() || isOwner(resource.data.wsId));
    }

    // ─── Join Requests (flat collection) ──────────────────────────────

    match /joinRequests/{reqId} {
      // Owner can read requests for their workspace; requester can read own
      allow read: if request.auth != null
                  && (isSuperAdmin()
                      || isOwner(resource.data.wsId)
                      || resource.data.userId == request.auth.uid);

      // Any authenticated user can create a join request — workspace must be active
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'PENDING'
                    && isWorkspaceActive(request.resource.data.wsId);

      // Only OWNER can approve/reject (NOT admins per requirements)
      allow update: if request.auth != null
                    && (isSuperAdmin() || isOwner(resource.data.wsId));

      allow delete: if request.auth != null
                    && (isSuperAdmin() || isOwner(resource.data.wsId));
    }

    // ─── Audit Logs ───────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow read: if request.auth != null
                  && (isMember(resource.data.wsId) || isSuperAdmin());

      allow create: if request.auth != null
                    && (canManage(request.resource.data.wsId) || isSuperAdmin());

      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    // ─── Tasks ────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      allow read: if request.auth != null
                  && (isSuperAdmin()
                      || (isMember(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow create: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(request.resource.data.wsId) && isWorkspaceActive(request.resource.data.wsId)));

      allow update: if request.auth != null
                    && (isSuperAdmin()
                        || (canEdit(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));

      allow delete: if request.auth != null
                    && (isSuperAdmin()
                        || (canManage(resource.data.wsId) && isWorkspaceActive(resource.data.wsId)));
    }
  }
}
